# OpenAI (para o agente de IA)
OPENAI_API_KEY=sk-...

# Supabase (banco de dados)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=xxxx
TWILIO_WHATSAPP_NUMBER=+55xxxxx

# Filesystem - diretório raiz para acesso a arquivos
FILES_ROOT_DIR=/tmp/pimpolho-files

# Rube MCP (Composio) - imagens, vídeos, Google Sheets
# Obter em: https://composio.dev → criar MCP server → copiar URL
RUBE_MCP_URL=
COMPOSIO_API_KEY=

# VoltOps (observabilidade - opcional)
VOLTAGENT_PUBLIC_KEY=
VOLTAGENT_SECRET_KEY=
